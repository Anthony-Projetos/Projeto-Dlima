[Unit]
Description=Dlima Vendas Gunicorn
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/dlima-vendas
EnvironmentFile=/var/www/dlima-vendas/.env
ExecStart=/var/www/dlima-vendas/venv/bin/gunicorn -c gunicorn.conf.py config.asgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
